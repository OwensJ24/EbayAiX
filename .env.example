ANTHROPIC_API_KEY=

# eBay Developer Program credentials (Sell APIs, OAuth 2.0 user token flow).
# Get these from https://developer.ebay.com/my/keys — use the Sandbox keyset
# while developing. EBAY_RU_NAME is not a URL; it's the "RuName" string eBay
# generates when you register a redirect URI for your keyset.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_RU_NAME=
EBAY_ENVIRONMENT=sandbox

# Separate PRODUCTION keyset for the read-only Browse API comp search
# (src/ebay/browse.py). eBay's sandbox has no real search/catalog data, so this
# always hits production regardless of EBAY_ENVIRONMENT above — safe, since
# it's a public read-only search, not listing creation. Get these from the
# same https://developer.ebay.com/my/keys page, under the Production keyset.
EBAY_PROD_APP_ID=
EBAY_PROD_CERT_ID=

# Optional: the public HTTPS base URL this app is served at, used to build
# image URLs eBay's Inventory API can fetch when creating a draft listing
# (e.g. https://ebayaix.onrender.com). Falls back to the incoming request's
# Host header if unset — only needs to be set explicitly if that's ever wrong
# (e.g. behind an unusual proxy setup).
PUBLIC_BASE_URL=
